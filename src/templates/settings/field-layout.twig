{% extends "docs-manager/_layouts/settings" %}
{% import '_includes/forms.twig' as forms %}

{% set title = 'Page Field Layout'|t('docs-manager') %}
{% set selectedSettingsItem = 'field-layout' %}
{% set fullPageForm = not (readOnly ?? false) %}
{% if readOnly ?? false %}
    {% set contentNotice = readOnlyNotice() %}
{% endif %}

{% set plugin = craft.app.plugins.getPlugin('docs-manager') %}
{% set crumbs = [
    {
        label: docsManagerHelper.fullName|t('docs-manager'),
        url: url('docs-manager'),
    },
    {
        label: 'Settings'|t('docs-manager'),
        url: url('docs-manager/settings'),
    },
] %}

{% block content %}
    {% if not (readOnly ?? false) %}
        {{ actionInput('docs-manager/settings/save-field-layout') }}
        {{ redirectInput('docs-manager/settings/field-layout') }}
    {% endif %}

    <div class="field">
        <p class="readable">
            {{ 'Add custom fields to Plugin Page elements. Any fields you add here will appear in the page edit screen for all custom pages (FAQ, Features, Support, etc.).'|t('docs-manager') }}
        </p>
    </div>

    {% if fieldLayout is defined and fieldLayout %}
        {{ forms.fieldLayoutDesignerField({
            fieldLayout: fieldLayout,
            disabled: readOnly ?? false,
        }) }}
    {% else %}
        <p class="notice">{{ 'No field layout available.'|t('docs-manager') }}</p>
    {% endif %}
{% endblock %}
