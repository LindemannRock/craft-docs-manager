{#
 # Pages Index — Using cp-table layout
 #
 # Follows the canonical CP table index-page pattern (in-memory variant) —
 # see plugins/base/docs/template-guides/cp-table-index-pattern.md.
 # PagesController::actionIndex() owns query-param parsing, allowlist
 # validation, filter, sort, and pagination. This template stays
 # presentational and renders the already-sliced `pages` plus the
 # filter/sort state handed in. Permission booleans (`canCreate`, `canEdit`,
 # `canDelete`, `canManage`) likewise arrive from the controller.
 #
 # @link      https://lindemannrock.com
 # @copyright Copyright (c) 2026 LindemannRock
 #}

{% extends 'lindemannrock-base/_layouts/cp-table' %}

{% set plugin = craft.app.plugins.getPlugin('docs-manager') %}

{# Build source lookup map for efficient name resolution in the row block. #}
{% set sourceMap = {} %}
{% for sourceRecord in sourceRecords %}
	{% set sourceMap = sourceMap|merge({ (sourceRecord.id): sourceRecord }) %}
{% endfor %}

{# Build sidebar items: "All Sources" + one per enabled source #}
{% set sidebarItems = {
	all: { label: 'All Sources'|t('docs-manager'), url: url('docs-manager/pages') },
} %}
{% for sourceRecord in sourceRecords %}
	{% set sidebarItems = sidebarItems|merge({
		('source-' ~ sourceRecord.id): {
			label: sourceRecord.name,
			url: url('docs-manager/pages', { sourceId: sourceRecord.id }),
		},
	}) %}
{% endfor %}

{# Determine selected sidebar item #}
{% set selectedSidebar = selectedSourceId ? ('source-' ~ selectedSourceId) : 'all' %}

{# Page type labels for display #}
{% set pageTypeLabels = {
	features: 'Features'|t('docs-manager'),
	faq: 'FAQ'|t('docs-manager'),
	support: 'Support'|t('docs-manager'),
	pricing: 'Pricing'|t('docs-manager'),
	custom: 'Custom'|t('docs-manager'),
} %}

{# Site crumb for multi-site #}
{% set siteCrumbs = [] %}
{% if craft.app.getIsMultiSite() %}
	{% set currentSite = craft.app.sites.getCurrentSite() %}
	{% set siteParam = craft.app.request.getParam('site') %}
	{% set selectedSiteHandle = siteParam ?: currentSite.handle %}
	{% set selectedSite = siteParam ? craft.app.sites.getSiteByHandle(siteParam) : currentSite %}

	{% set siteMenuItems = [] %}
	{% for site in plugin.getEnabledSites() %}
		{% set siteMenuItems = siteMenuItems|merge([{
			label: site.name,
			url: url('docs-manager/pages', {site: site.handle}),
			selected: site.handle == selectedSiteHandle
		}]) %}
	{% endfor %}

	{% set siteCrumbs = [{
		id: 'site-crumb',
		icon: 'world',
		label: selectedSite.name|t('site'),
		menu: {
			items: siteMenuItems,
			label: 'Select site'|t('docs-manager')
		}
	}] %}
{% endif %}

{% set tableConfig = {
	plugin: {
		handle: 'docs-manager',
		name: docsManagerHelper.fullName,
	},
	page: {
		title: 'Pages'|t('docs-manager'),
		subnav: 'pages',
		crumbs: siteCrumbs|merge([
			{ label: docsManagerHelper.fullName, url: url('docs-manager') },
			{ label: 'Pages'|t('docs-manager'), url: url('docs-manager/pages') },
		]),
	},
	sidebarMenu: {
		label: 'Sources'|t('docs-manager'),
		items: sidebarItems,
		selected: selectedSidebar,
	},
	filters: [
		{
			type: 'status',
			param: 'status',
			current: statusFilter,
			label: 'All'|t('docs-manager'),
			groups: [
				{
					param: 'status',
					current: statusFilter,
					colorSet: 'status',
					options: [
						{value: 'all', label: 'All'|t('docs-manager'), status: 'all'},
						{value: 'enabled', label: 'Enabled'|t('docs-manager'), colorKey: 'enabled'},
						{value: 'disabled', label: 'Disabled'|t('docs-manager'), colorKey: 'disabled'},
					],
				},
				{
					header: 'Page Type'|t('docs-manager'),
					param: 'type',
					current: typeFilter,
					colorSet: 'pageType',
					options: [
						{value: 'all', label: 'All Types'|t('docs-manager'), status: 'all'},
						{value: 'features', label: 'Features'|t('docs-manager'), colorKey: 'features'},
						{value: 'faq', label: 'FAQ'|t('docs-manager'), colorKey: 'faq'},
						{value: 'support', label: 'Support'|t('docs-manager'), colorKey: 'support'},
						{value: 'pricing', label: 'Pricing'|t('docs-manager'), colorKey: 'pricing'},
						{value: 'custom', label: 'Custom'|t('docs-manager'), colorKey: 'custom'},
					],
				},
			],
		},
	],
	search: {
		placeholder: 'Search pages...'|t('docs-manager'),
		value: search,
	},
	sort: {
		field: sort,
		direction: dir,
	},
	table: {
		columns: [
			{key: 'title', label: 'Title'|t('docs-manager'), sortable: true},
			{key: 'source', label: 'Source'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'pageType', label: 'Type'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'slug', label: 'Slug'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'enabled', label: 'Status'|t('docs-manager'), sortable: true, hideable: true},
		],
		items: pages,
		emptyMessage: 'No custom pages found.'|t('docs-manager'),
	},
	pagination: {
		page: page,
		limit: limit,
		totalCount: totalCount,
		itemLabel: {singular: 'page'|t('docs-manager'), plural: 'pages'|t('docs-manager')},
	},
	checkboxes: canManage,
	newButton: (selectedSourceId and canCreate) ? {
		url: url('docs-manager/pages/new/' ~ selectedSourceId),
		label: 'New Page'|t('docs-manager'),
	} : null,
} %}

{% block toolbarActions %}
	{% if not selectedSourceId and canCreate and sourceRecords|length %}
		<div class="btngroup submit">
			<button type="button" class="btn submit add icon menubtn">{{ 'New Page'|t('docs-manager') }}</button>
			<div class="menu">
				<ul>
					{% for sourceRecord in sourceRecords %}
						<li>
							<a href="{{ url('docs-manager/pages/new/' ~ sourceRecord.id) }}">{{ sourceRecord.name }}</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>
	{% endif %}
{% endblock %}

{% block tableRow %}
	{% set sourceRecord = sourceMap[item.sourceId] ?? null %}

	{# Title #}
	<td data-column="title">
		<a class="label-link" href="{{ url('docs-manager/pages/' ~ item.id) }}">
			<span>{{ item.title }}</span>
		</a>
	</td>

	{# Source #}
	<td data-column="source">
		{% if sourceRecord %}
			<a href="{{ url('docs-manager/pages', { sourceId: sourceRecord.id }) }}">{{ sourceRecord.name }}</a>
		{% else %}
			<span class="light">-</span>
		{% endif %}
	</td>

	{# Type #}
	<td data-column="pageType">
		{% include 'lindemannrock-base/_components/badge' with {
			label: pageTypeLabels[item.pageType] ?? item.pageType|capitalize,
			value: item.pageType,
			colorSet: 'pageType',
		} only %}
	</td>

	{# Slug #}
	<td data-column="slug">
		<code>{{ item.slug }}</code>
	</td>

	{# Status #}
	<td data-column="enabled">
		{% include 'lindemannrock-base/_components/badge' with {
			label: item.enabled ? 'Enabled'|t('docs-manager') : 'Disabled'|t('docs-manager'),
			value: item.enabled ? 'enabled' : 'disabled',
			colorSet: 'status',
		} only %}
	</td>
{% endblock %}

{% block rowActions %}
	{% set actionItems = [] %}

	{% if canEdit %}
		{% set actionItems = actionItems|merge([{
			label: 'Edit'|t('docs-manager'),
			url: url('docs-manager/pages/' ~ item.id),
		}]) %}
	{% endif %}

	{% if canDelete %}
		{% if actionItems|length %}
			{% set actionItems = actionItems|merge([{type: 'divider'}]) %}
		{% endif %}
		{% set actionItems = actionItems|merge([{
			label: 'Delete'|t('docs-manager'),
			class: 'error',
			jsAction: 'delete',
			data: {name: item.title},
		}]) %}
	{% endif %}

	{% if actionItems|length > 0 %}
		{% include 'lindemannrock-base/_components/row-actions' with {
			item: item,
			actions: {
				type: 'menu',
				icon: 'settings',
				title: 'Actions'|t('docs-manager'),
				items: actionItems,
			},
		} only %}
	{% endif %}
{% endblock %}

{% block bulkActions %}
	{% if canEdit %}
		{% include 'lindemannrock-base/_components/bulk-status-menu' with {
			label: 'Set status'|t('docs-manager'),
			countId: 'lr-bulk-status-count',
			items: [
				{id: 'lr-bulk-enable-action', label: 'Enable'|t('docs-manager'), status: 'enabled'},
				{id: 'lr-bulk-disable-action', label: 'Disable'|t('docs-manager'), status: 'disabled'},
			],
		} only %}
	{% endif %}
	{% if canDelete %}
		{% include 'lindemannrock-base/_components/bulk-actions-menu' with {
			label: 'Actions'|t('docs-manager'),
			countId: 'lr-bulk-actions-count',
			items: [
				{id: 'lr-bulk-delete-btn', label: 'Delete'|t('docs-manager'), class: 'error'},
			],
		} only %}
	{% endif %}
{% endblock %}

{% block scripts %}
<script>
(function() {
	if (typeof Craft === 'undefined') return;

	// Initialise the "New Page" source-picker menubtn (when no source is selected).
	document.querySelectorAll('.btngroup.submit .menubtn').forEach(function(btn) {
		if (Craft.MenuBtn) {
			new Craft.MenuBtn(btn);
		}
	});

	// Pre-translated strings: keep |t() in Twig and emit as JSON-encoded JS
	// literals via |json_encode|raw — avoids the |e('js') trap.
	const T = {
		deleteConfirmTemplate: {{ 'Delete page "{name}"? This cannot be undone.'|t('docs-manager')|json_encode|raw }},
		pageDeleted: {{ 'Page deleted'|t('docs-manager')|json_encode|raw }},
		failedToDeletePage: {{ 'Failed to delete page'|t('docs-manager')|json_encode|raw }},
		bulkEnabledTemplate: {{ 'Enabled {count} pages'|t('docs-manager')|json_encode|raw }},
		bulkEnableFailed: {{ 'Failed to enable pages'|t('docs-manager')|json_encode|raw }},
		bulkDisabledTemplate: {{ 'Disabled {count} pages'|t('docs-manager')|json_encode|raw }},
		bulkDisableFailed: {{ 'Failed to disable pages'|t('docs-manager')|json_encode|raw }},
		bulkDeletedTemplate: {{ 'Deleted {count} pages'|t('docs-manager')|json_encode|raw }},
		bulkDeleteFailed: {{ 'Failed to delete pages'|t('docs-manager')|json_encode|raw }},
		bulkDeleteConfirmTemplate: {{ 'Delete {count} page(s)? This cannot be undone.'|t('docs-manager')|json_encode|raw }},
	};

	function selectedIds() {
		return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
	}

	// ---------------------------------------------------------------------
	// Row-action handlers. Delegated listener on `document`, narrowed by
	// `a[data-action]` + an explicit action-name allowlist. preventDefault
	// only after the match — leaves unrelated `data-action` elements alone.
	// See cp-table-index-pattern.md.
	// ---------------------------------------------------------------------
	document.addEventListener('click', function(e) {
		const trigger = e.target.closest('a[data-action]');
		if (!trigger) return;

		const action = trigger.dataset.action;
		if (action !== 'delete') return;

		const id = trigger.dataset.id;
		const name = trigger.dataset.name || '';
		if (!id) return;
		e.preventDefault();

		if (!confirm(T.deleteConfirmTemplate.replace('{name}', name))) return;

		Craft.sendActionRequest('POST', 'docs-manager/pages/delete', {
			data: { pageId: id },
		}).then(function(response) {
			if (response.data.success) {
				Craft.cp.displayNotice(T.pageDeleted);
				setTimeout(function() { window.location.reload(); }, 1000);
			} else {
				Craft.cp.displayError(response.data.error || T.failedToDeletePage);
			}
		}).catch(function() {
			Craft.cp.displayError(T.failedToDeletePage);
		});
	});

	// ---------------------------------------------------------------------
	// Bulk actions. Each posts the selected IDs to its endpoint; the
	// controller returns `count` (rows successfully changed) plus an
	// optional `errors` array for per-row failures.
	// ---------------------------------------------------------------------
	function runBulkStatus(endpoint, successTemplate, errorFallback) {
		const ids = selectedIds();
		if (!ids.length) return;
		Craft.sendActionRequest('POST', endpoint, {
			data: { pageIds: ids },
		}).then(function(response) {
			const count = response.data.count || 0;
			if (count > 0) {
				Craft.cp.displayNotice(successTemplate.replace('{count}', count));
			}
			if (Array.isArray(response.data.errors)) {
				response.data.errors.forEach(function(err) { Craft.cp.displayError(err); });
			}
			if (count > 0 && (!Array.isArray(response.data.errors) || response.data.errors.length === 0)) {
				setTimeout(function() { window.location.reload(); }, 1000);
			}
		}).catch(function() {
			Craft.cp.displayError(errorFallback);
		});
	}

	document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		runBulkStatus('docs-manager/pages/bulk-enable', T.bulkEnabledTemplate, T.bulkEnableFailed);
	});

	document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		runBulkStatus('docs-manager/pages/bulk-disable', T.bulkDisabledTemplate, T.bulkDisableFailed);
	});

	document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
		const ids = selectedIds();
		if (!ids.length) return;
		if (!confirm(T.bulkDeleteConfirmTemplate.replace('{count}', ids.length))) return;
		runBulkStatus('docs-manager/pages/bulk-delete', T.bulkDeletedTemplate, T.bulkDeleteFailed);
	});

})();
</script>
{% endblock %}
