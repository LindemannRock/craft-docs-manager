{% extends 'lindemannrock-base/_layouts/cp-table' %}

{% set plugin = craft.app.plugins.getPlugin('docs-manager') %}
{% set settings = plugin.getSettings() %}

{# Get query parameters #}
{% set search = craft.app.request.getParam('search', '') %}
{% set statusFilter = craft.app.request.getParam('status', 'all') %}
{% set typeFilter = craft.app.request.getParam('type', 'all') %}
{% set sort = craft.app.request.getParam('sort', 'title') %}
{% set dir = craft.app.request.getParam('dir', 'asc') %}
{% set page = craft.app.request.getParam('page', 1)|number_format(0, '', '') %}
{% set limit = settings.itemsPerPage %}
{% set offset = (page - 1) * limit %}

{# Permission checks #}
{% set canManage = currentUser.can('docsManager:managePages') %}

{# Build source lookup map for efficient name resolution #}
{% set sourceMap = {} %}
{% for sourceRecord in sourceRecords %}
	{% set sourceMap = sourceMap|merge({ (sourceRecord.id): sourceRecord }) %}
{% endfor %}

{# Build sidebar items: "All Sources" + one per enabled source #}
{% set sidebarItems = {
	all: { label: 'All Sources'|t('docs-manager'), url: url('docs-manager/pages') },
} %}
{% for sourceRecord in sourceRecords %}
	{% set sidebarItems = sidebarItems|merge({
		('source-' ~ sourceRecord.id): {
			label: sourceRecord.name,
			url: url('docs-manager/pages', { sourceId: sourceRecord.id }),
		},
	}) %}
{% endfor %}

{# Determine selected sidebar item #}
{% set selectedSidebar = selectedSourceId ? ('source-' ~ selectedSourceId) : 'all' %}

{# Filter pages based on filters #}
{% set filteredPages = pages %}

{# Status filter #}
{% if statusFilter == 'enabled' %}
	{% set filteredPages = filteredPages|filter(p => p.enabled) %}
{% elseif statusFilter == 'disabled' %}
	{% set filteredPages = filteredPages|filter(p => not p.enabled) %}
{% endif %}

{# Type filter #}
{% if typeFilter != 'all' %}
	{% set filteredPages = filteredPages|filter(p => p.pageType == typeFilter) %}
{% endif %}

{# Search filter #}
{% if search %}
	{% set filteredPages = filteredPages|filter(p => search|lower in p.title|lower or search|lower in (p.slug ?? '')|lower) %}
{% endif %}

{# Sort #}
{% if sort == 'title' %}
	{% set filteredPages = dir == 'asc' ? filteredPages|sort((a, b) => a.title|lower <=> b.title|lower) : filteredPages|sort((a, b) => b.title|lower <=> a.title|lower) %}
{% elseif sort == 'source' %}
	{% set filteredPages = dir == 'asc' ? filteredPages|sort((a, b) => (sourceMap[a.sourceId].name ?? '')|lower <=> (sourceMap[b.sourceId].name ?? '')|lower) : filteredPages|sort((a, b) => (sourceMap[b.sourceId].name ?? '')|lower <=> (sourceMap[a.sourceId].name ?? '')|lower) %}
{% elseif sort == 'pageType' %}
	{% set filteredPages = dir == 'asc' ? filteredPages|sort((a, b) => a.pageType|lower <=> b.pageType|lower) : filteredPages|sort((a, b) => b.pageType|lower <=> a.pageType|lower) %}
{% elseif sort == 'slug' %}
	{% set filteredPages = dir == 'asc' ? filteredPages|sort((a, b) => (a.slug ?? '')|lower <=> (b.slug ?? '')|lower) : filteredPages|sort((a, b) => (b.slug ?? '')|lower <=> (a.slug ?? '')|lower) %}
{% elseif sort == 'enabled' %}
	{% set filteredPages = dir == 'asc' ? filteredPages|sort((a, b) => a.enabled <=> b.enabled) : filteredPages|sort((a, b) => b.enabled <=> a.enabled) %}
{% endif %}

{# Pagination #}
{% set totalCount = filteredPages|length %}
{% set paginatedItems = filteredPages|slice(offset, limit) %}

{# Page type labels for display #}
{% set pageTypeLabels = {
	features: 'Features',
	faq: 'FAQ',
	support: 'Support',
	pricing: 'Pricing',
	custom: 'Custom',
} %}

{# Site crumb for multi-site #}
{% set siteCrumbs = [] %}
{% if craft.app.getIsMultiSite() %}
	{% set currentSite = craft.app.sites.getCurrentSite() %}
	{% set siteParam = craft.app.request.getParam('site') %}
	{% set selectedSiteHandle = siteParam ?: currentSite.handle %}
	{% set selectedSite = siteParam ? craft.app.sites.getSiteByHandle(siteParam) : currentSite %}

	{% set siteMenuItems = [] %}
	{% for site in plugin.getEnabledSites() %}
		{% set siteMenuItems = siteMenuItems|merge([{
			label: site.name,
			url: url('docs-manager/pages', {site: site.handle}),
			selected: site.handle == selectedSiteHandle
		}]) %}
	{% endfor %}

	{% set siteCrumbs = [{
		id: 'site-crumb',
		icon: 'world',
		label: selectedSite.name|t('site'),
		menu: {
			items: siteMenuItems,
			label: 'Select site'|t('docs-manager')
		}
	}] %}
{% endif %}

{% set tableConfig = {
	plugin: {
		handle: 'docs-manager',
		name: docsManagerHelper.fullName,
	},
	page: {
		title: 'Pages'|t('docs-manager'),
		subnav: 'pages',
		crumbs: siteCrumbs|merge([
			{ label: docsManagerHelper.fullName, url: url('docs-manager') },
			{ label: 'Pages'|t('docs-manager'), url: url('docs-manager/pages') },
		]),
	},
	sidebarMenu: {
		label: 'Sources'|t('docs-manager'),
		items: sidebarItems,
		selected: selectedSidebar,
	},
	filters: [
		{
			type: 'status',
			param: 'status',
			current: statusFilter,
			label: 'All'|t('docs-manager'),
			groups: [
				{
					param: 'status',
					current: statusFilter,
					options: [
						{value: 'all', label: 'All'|t('docs-manager'), status: 'all'},
						{value: 'enabled', label: 'Enabled'|t('docs-manager'), status: 'green'},
						{value: 'disabled', label: 'Disabled'|t('docs-manager'), status: 'disabled'},
					],
				},
				{
					header: 'Page Type'|t('docs-manager'),
					param: 'type',
					current: typeFilter,
					colorSet: 'pageType',
					options: [
						{value: 'all', label: 'All Types'|t('docs-manager'), status: 'all'},
						{value: 'features', label: 'Features'|t('docs-manager'), colorKey: 'features'},
						{value: 'faq', label: 'FAQ'|t('docs-manager'), colorKey: 'faq'},
						{value: 'support', label: 'Support'|t('docs-manager'), colorKey: 'support'},
						{value: 'pricing', label: 'Pricing'|t('docs-manager'), colorKey: 'pricing'},
						{value: 'custom', label: 'Custom'|t('docs-manager'), colorKey: 'custom'},
					],
				},
			],
		},
	],
	search: {
		placeholder: 'Search pages...'|t('docs-manager'),
		value: search,
	},
	sort: {
		field: sort,
		direction: dir,
	},
	table: {
		columns: [
			{key: 'title', label: 'Title'|t('docs-manager'), sortable: true},
			{key: 'source', label: 'Source'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'pageType', label: 'Type'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'slug', label: 'Slug'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'enabled', label: 'Status'|t('docs-manager'), sortable: true, hideable: true},
		],
		items: paginatedItems,
		emptyMessage: 'No custom pages found.'|t('docs-manager'),
	},
	pagination: {
		page: page,
		limit: limit,
		totalCount: totalCount,
		itemLabel: {singular: 'page'|t('docs-manager'), plural: 'pages'|t('docs-manager')},
	},
	checkboxes: canManage,
	newButton: selectedSourceId ? {
		url: url('docs-manager/pages/new/' ~ selectedSourceId),
		label: 'New Page'|t('docs-manager'),
		permission: 'docsManager:createPages',
	} : false,
} %}

{% block toolbarActions %}
	{% if not selectedSourceId and canManage and sourceRecords|length %}
		<div class="btngroup submit">
			<button type="button" class="btn submit add icon menubtn">{{ 'New Page'|t('docs-manager') }}</button>
			<div class="menu">
				<ul>
					{% for sourceRecord in sourceRecords %}
						<li>
							<a href="{{ url('docs-manager/pages/new/' ~ sourceRecord.id) }}">{{ sourceRecord.name }}</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>
	{% endif %}
{% endblock %}

{% block tableRow %}
	{% set sourceRecord = sourceMap[item.sourceId] ?? null %}

	{# Title #}
	<td data-column="title">
		<a class="label-link" href="{{ url('docs-manager/pages/' ~ item.id) }}">
			<span>{{ item.title }}</span>
		</a>
	</td>

	{# Source #}
	<td data-column="source">
		{% if sourceRecord %}
			<a href="{{ url('docs-manager/pages', { sourceId: sourceRecord.id }) }}">{{ sourceRecord.name }}</a>
		{% else %}
			<span class="light">-</span>
		{% endif %}
	</td>

	{# Type #}
	<td data-column="pageType">
		{% include 'lindemannrock-base/_components/badge' with {
			label: pageTypeLabels[item.pageType] ?? item.pageType|capitalize,
			value: item.pageType,
			colorSet: 'pageType',
		} only %}
	</td>

	{# Slug #}
	<td data-column="slug">
		<code>{{ item.slug }}</code>
	</td>

	{# Status #}
	<td data-column="enabled">
		{% include 'lindemannrock-base/_components/badge' with {
			label: item.enabled ? 'Enabled'|t('docs-manager') : 'Disabled'|t('docs-manager'),
			value: item.enabled ? 'enabled' : 'disabled',
			colorSet: 'status',
		} only %}
	</td>
{% endblock %}

{% block rowActions %}
	{% set actionItems = [] %}

	{% if canManage %}
		{% set actionItems = actionItems|merge([{
			label: 'Edit'|t('docs-manager'),
			url: url('docs-manager/pages/' ~ item.id),
		}]) %}
		{% set actionItems = actionItems|merge([
			{type: 'divider'},
			{
				label: 'Delete'|t('docs-manager'),
				class: 'error',
				jsAction: 'delete',
				data: {name: item.title},
			},
		]) %}
	{% endif %}

	{% if actionItems|length > 0 %}
		{% include 'lindemannrock-base/_components/row-actions' with {
			item: item,
			actions: {
				type: 'menu',
				icon: 'settings',
				title: 'Actions'|t('docs-manager'),
				items: actionItems,
			},
		} only %}
	{% endif %}
{% endblock %}

{% block bulkActions %}
	{% if canManage %}
		<button type="button" class="btn menubtn secondary" id="lr-bulk-status-btn">
			{{ 'Set status'|t('docs-manager') }}
		</button>
		<div class="menu">
			<ul>
				<li><a id="lr-bulk-enable-action">{{ 'Enable'|t('docs-manager') }}</a></li>
				<li><a id="lr-bulk-disable-action">{{ 'Disable'|t('docs-manager') }}</a></li>
			</ul>
		</div>

		<button type="button" class="btn secondary" id="lr-bulk-delete-btn">
			{{ 'Delete'|t('docs-manager') }} (<span id="lr-selected-count">0</span>)
		</button>
	{% endif %}
{% endblock %}

{% block scripts %}
<script>
(function() {
	// Initialize "New Page" source dropdown menu
	document.querySelectorAll('.btngroup.submit .menubtn').forEach(function(btn) {
		if (typeof Craft !== 'undefined' && Craft.MenuBtn) {
			new Craft.MenuBtn(btn);
		}
	});

	// Initialize bulk status menu
	const bulkStatusBtn = document.getElementById('lr-bulk-status-btn');
	if (bulkStatusBtn && typeof Craft !== 'undefined' && Craft.MenuBtn) {
		new Craft.MenuBtn(bulkStatusBtn);
	}

	// Bulk enable
	document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		const ids = window.lrTableSelection.getSelectedIds();
		if (ids.length === 0) return;

		Craft.sendActionRequest('POST', 'docs-manager/pages/bulk-enable', {
			data: { pageIds: ids }
		}).then(function(response) {
			if (response.data.success) {
				Craft.cp.displayNotice(Craft.t('docs-manager', 'Enabled {count} page(s)', {count: response.data.count}));
				setTimeout(() => window.location.reload(), 1000);
			}
		}).catch(function() {
			Craft.cp.displayError(Craft.t('docs-manager', 'Failed to enable pages'));
		});
	});

	// Bulk disable
	document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		const ids = window.lrTableSelection.getSelectedIds();
		if (ids.length === 0) return;

		Craft.sendActionRequest('POST', 'docs-manager/pages/bulk-disable', {
			data: { pageIds: ids }
		}).then(function(response) {
			if (response.data.count > 0) {
				Craft.cp.displayNotice(Craft.t('docs-manager', 'Disabled {count} page(s)', {count: response.data.count}));
			}
			if (response.data.errors && response.data.errors.length > 0) {
				response.data.errors.forEach(err => Craft.cp.displayError(err));
			}
			if (response.data.count > 0 && (!response.data.errors || response.data.errors.length === 0)) {
				setTimeout(() => window.location.reload(), 1000);
			}
		}).catch(function() {
			Craft.cp.displayError(Craft.t('docs-manager', 'Failed to disable pages'));
		});
	});

	// Bulk delete
	document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
		const ids = window.lrTableSelection.getSelectedIds();
		if (ids.length === 0) return;

		if (!confirm(Craft.t('docs-manager', 'Delete {count} page(s)? This cannot be undone.', {count: ids.length}))) return;

		Craft.sendActionRequest('POST', 'docs-manager/pages/bulk-delete', {
			data: { pageIds: ids }
		}).then(function(response) {
			if (response.data.count > 0) {
				Craft.cp.displayNotice(Craft.t('docs-manager', 'Deleted {count} page(s)', {count: response.data.count}));
			}
			if (response.data.errors && response.data.errors.length > 0) {
				response.data.errors.forEach(err => Craft.cp.displayError(err));
			}
			if (response.data.count > 0 && (!response.data.errors || response.data.errors.length === 0)) {
				setTimeout(() => window.location.reload(), 1000);
			}
		}).catch(function() {
			Craft.cp.displayError(Craft.t('docs-manager', 'Failed to delete pages'));
		});
	});

	// Individual delete action
	document.querySelectorAll('[data-action="delete"]').forEach(function(btn) {
		btn.addEventListener('click', function(e) {
			e.preventDefault();
			const id = this.dataset.id;
			const name = this.dataset.name || '';

			if (!id) return;

			if (!confirm(Craft.t('docs-manager', 'Delete page "{name}"? This cannot be undone.', {name: name}))) return;

			Craft.sendActionRequest('POST', 'docs-manager/pages/delete', {
				data: { pageId: id }
			}).then(function(response) {
				if (response.data.success) {
					Craft.cp.displayNotice(Craft.t('docs-manager', 'Page deleted'));
					setTimeout(() => window.location.reload(), 1000);
				} else {
					Craft.cp.displayError(response.data.error || Craft.t('docs-manager', 'Failed to delete page'));
				}
			}).catch(function() {
				Craft.cp.displayError(Craft.t('docs-manager', 'Failed to delete page'));
			});
		});
	});

	// Update selected count
	document.addEventListener('lr:selectionChanged', function(e) {
		const countSpan = document.getElementById('lr-selected-count');
		if (countSpan) {
			countSpan.textContent = e.detail.count;
		}
	});
})();
</script>
{% endblock %}
