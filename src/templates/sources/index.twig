{#
 # Sources Index — Using cp-table layout
 #
 # Follows the canonical CP table index-page pattern (in-memory variant) —
 # see plugins/base/docs/template-guides/cp-table-index-pattern.md.
 # SourcesController::actionIndex() owns query-param parsing, allowlist
 # validation, filter, sort, and pagination. This template stays
 # presentational and renders the already-sliced `sources` plus the
 # filter/sort state handed in. Permission booleans (`canCreate`, `canEdit`,
 # `canDelete`, `canManage`) likewise arrive from the controller.
 #
 # @link      https://lindemannrock.com
 # @copyright Copyright (c) 2026 LindemannRock
 #}

{% extends 'lindemannrock-base/_layouts/cp-table' %}

{% set plugin = craft.app.plugins.getPlugin('docs-manager') %}

{# Site crumb for multi-site #}
{% set siteCrumbs = [] %}
{% if craft.app.getIsMultiSite() %}
	{% set currentSite = craft.app.sites.getCurrentSite() %}
	{% set siteParam = craft.app.request.getParam('site') %}
	{% set selectedSiteHandle = siteParam ?: currentSite.handle %}
	{% set selectedSite = siteParam ? craft.app.sites.getSiteByHandle(siteParam) : currentSite %}

	{% set siteMenuItems = [] %}
	{% for site in plugin.getEnabledSites() %}
		{% set siteMenuItems = siteMenuItems|merge([{
			label: site.name,
			url: url('docs-manager/sources', {site: site.handle}),
			selected: site.handle == selectedSiteHandle
		}]) %}
	{% endfor %}

	{% set siteCrumbs = [{
		id: 'site-crumb',
		icon: 'world',
		label: selectedSite.name|t('site'),
		menu: {
			items: siteMenuItems,
			label: 'Select site'|t('docs-manager')
		}
	}] %}
{% endif %}

{% set tableConfig = {
	plugin: {
		handle: 'docs-manager',
		name: docsManagerHelper.fullName,
	},
	page: {
		title: 'Sources'|t('docs-manager'),
		subnav: 'sources',
		crumbs: siteCrumbs|merge([
			{ label: docsManagerHelper.fullName, url: url('docs-manager') },
			{ label: 'Sources'|t('docs-manager'), url: url('docs-manager/sources') },
		]),
	},
	filters: [
		{
			type: 'status',
			param: 'status',
			current: statusFilter,
			label: 'All'|t('docs-manager'),
			groups: [
				{
					param: 'status',
					current: statusFilter,
					colorSet: 'status',
					options: [
						{value: 'all', label: 'All'|t('docs-manager'), status: 'all'},
						{value: 'enabled', label: 'Enabled'|t('docs-manager'), colorKey: 'enabled'},
						{value: 'disabled', label: 'Disabled'|t('docs-manager'), colorKey: 'disabled'},
					],
				},
				{
					header: 'Doc Type'|t('docs-manager'),
					param: 'kind',
					current: kindFilter,
					colorSet: 'sourceKind',
					options: [
						{value: 'all', label: 'All Types'|t('docs-manager'), status: 'all'},
						{value: 'plugin', label: 'Plugin'|t('docs-manager'), colorKey: 'plugin'},
						{value: 'theme', label: 'Theme'|t('docs-manager'), colorKey: 'theme'},
					],
				},
			],
		},
	],
	search: {
		placeholder: 'Search sources...'|t('docs-manager'),
		value: search,
	},
	sort: {
		field: sort,
		direction: dir,
	},
	table: {
		columns: [
			{key: 'name', label: 'Name'|t('docs-manager'), sortable: true},
			{key: 'handle', label: 'Handle'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'kind', label: 'Doc Type'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'currentVersion', label: 'Version'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'pages', label: 'Pages'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'lastSyncedAt', label: 'Last Synced'|t('docs-manager'), sortable: true, hideable: true},
			{key: 'enabled', label: 'Status'|t('docs-manager'), sortable: true, hideable: true},
		],
		items: sources,
		emptyMessage: 'No sources found.'|t('docs-manager'),
	},
	pagination: {
		page: page,
		limit: limit,
		totalCount: totalCount,
		itemLabel: {singular: 'source'|t('docs-manager'), plural: 'sources'|t('docs-manager')},
	},
	checkboxes: canManage,
	newButton: canCreate ? {
		url: url('docs-manager/sources/new'),
		label: 'New Source'|t('docs-manager'),
	} : null,
} %}

{% block toolbarActions %}
	{% if canEdit %}
		<button type="button" class="btn" id="sync-all-btn">{{ 'Sync All'|t('docs-manager') }}</button>
	{% endif %}
{% endblock %}

{% block tableRow %}
	{# Name #}
	<td data-column="name">
		<a class="label-link" href="{{ url('docs-manager/sources/' ~ item.id) }}">
			<span>{{ item.name }}</span>
		</a>
	</td>

	{# Handle #}
	<td data-column="handle">
		<code>{{ item.handle }}</code>
	</td>

	{# Doc Type #}
	<td data-column="kind">
		{% include 'lindemannrock-base/_components/badge' with {
			label: item.kind|capitalize,
			value: item.kind,
			colorSet: 'sourceKind',
		} only %}
	</td>

	{# Version #}
	<td data-column="currentVersion">
		{{ item.currentVersion ?? '--' }}
	</td>

	{# Pages — pre-computed in the controller via a single GROUP BY query
	   (was N+1: `craft.docsManager.getPages(item.handle)|length` ran a
	   fresh element query per visible row). #}
	<td data-column="pages">
		{{ pageCounts[item.id] ?? 0 }}
	</td>

	{# Last Synced #}
	<td data-column="lastSyncedAt">
		{% if item.lastSyncedAt %}
			{{ item.lastSyncedAt|lrDatetime }}
		{% else %}
			<span class="light">--</span>
		{% endif %}
	</td>

	{# Status #}
	<td data-column="enabled">
		{% include 'lindemannrock-base/_components/badge' with {
			label: item.enabled ? 'Enabled'|t('docs-manager') : 'Disabled'|t('docs-manager'),
			value: item.enabled ? 'enabled' : 'disabled',
			colorSet: 'status',
		} only %}
	</td>
{% endblock %}

{% block rowActions %}
	{% set actionItems = [
		{
			label: 'Edit'|t('docs-manager'),
			url: url('docs-manager/sources/' ~ item.id),
		},
		{
			label: 'Sync'|t('docs-manager'),
			jsAction: 'sync',
			data: {name: item.name},
		},
	] %}

	{% if canDelete %}
		{% set actionItems = actionItems|merge([
			{type: 'divider'},
			{
				label: 'Delete'|t('docs-manager'),
				class: 'error',
				jsAction: 'delete',
				data: {name: item.name},
			},
		]) %}
	{% endif %}

	{% include 'lindemannrock-base/_components/row-actions' with {
		item: item,
		actions: {
			type: 'menu',
			icon: 'settings',
			title: 'Actions'|t('docs-manager'),
			items: actionItems,
		},
	} only %}
{% endblock %}

{% block bulkActions %}
	{% if canEdit %}
		{% include 'lindemannrock-base/_components/bulk-status-menu' with {
			label: 'Set status'|t('docs-manager'),
			countId: 'lr-bulk-status-count',
			items: [
				{id: 'lr-bulk-enable-action', label: 'Enable'|t('docs-manager'), status: 'enabled'},
				{id: 'lr-bulk-disable-action', label: 'Disable'|t('docs-manager'), status: 'disabled'},
			],
		} only %}
	{% endif %}
	{% if canDelete %}
		{% include 'lindemannrock-base/_components/bulk-actions-menu' with {
			label: 'Actions'|t('docs-manager'),
			countId: 'lr-bulk-actions-count',
			items: [
				{id: 'lr-bulk-delete-btn', label: 'Delete'|t('docs-manager'), class: 'error'},
			],
		} only %}
	{% endif %}
{% endblock %}

{% block scripts %}
<script>
(function() {
	if (typeof Craft === 'undefined') return;

	// Pre-translated strings: keep |t() in Twig and emit as JSON-encoded JS
	// literals via |json_encode|raw — avoids the |e('js') trap.
	const T = {
		syncAllConfirm: {{ 'Sync all enabled sources? This may take a while.'|t('docs-manager')|json_encode|raw }},
		syncing: {{ 'Syncing...'|t('docs-manager')|json_encode|raw }},
		syncAllSuccess: {{ 'All sources synced successfully'|t('docs-manager')|json_encode|raw }},
		syncAllPartial: {{ 'Some sources failed to sync'|t('docs-manager')|json_encode|raw }},
		syncAllFailed: {{ 'Failed to sync sources'|t('docs-manager')|json_encode|raw }},
		sourceSyncedTemplate: {{ 'Source "{name}" synced'|t('docs-manager')|json_encode|raw }},
		syncFailed: {{ 'Sync failed'|t('docs-manager')|json_encode|raw }},
		failedToSyncSource: {{ 'Failed to sync source'|t('docs-manager')|json_encode|raw }},
		deleteConfirmTemplate: {{ 'Delete source "{name}"? This cannot be undone.'|t('docs-manager')|json_encode|raw }},
		sourceDeleted: {{ 'Source deleted'|t('docs-manager')|json_encode|raw }},
		failedToDeleteSource: {{ 'Failed to delete source'|t('docs-manager')|json_encode|raw }},
		bulkEnabledTemplate: {{ 'Enabled {count} sources'|t('docs-manager')|json_encode|raw }},
		bulkEnableFailed: {{ 'Failed to enable sources'|t('docs-manager')|json_encode|raw }},
		bulkDisabledTemplate: {{ 'Disabled {count} sources'|t('docs-manager')|json_encode|raw }},
		bulkDisableFailed: {{ 'Failed to disable sources'|t('docs-manager')|json_encode|raw }},
		bulkDeletedTemplate: {{ 'Deleted {count} sources'|t('docs-manager')|json_encode|raw }},
		bulkDeleteFailed: {{ 'Failed to delete sources'|t('docs-manager')|json_encode|raw }},
		bulkDeleteConfirmSingular: {{ 'Delete {count} source? This cannot be undone.'|t('docs-manager')|json_encode|raw }},
		bulkDeleteConfirmPlural: {{ 'Delete {count} sources? This cannot be undone.'|t('docs-manager')|json_encode|raw }},
	};

	function selectedIds() {
		return window.lrTableSelection ? window.lrTableSelection.getSelectedIds() : [];
	}

	// Sync All toolbar button.
	document.getElementById('sync-all-btn')?.addEventListener('click', function() {
		if (!confirm(T.syncAllConfirm)) return;

		const btn = this;
		const originalText = btn.textContent;
		btn.disabled = true;
		btn.textContent = T.syncing;

		Craft.sendActionRequest('POST', 'docs-manager/sources/sync-all')
			.then(function(response) {
				btn.disabled = false;
				btn.textContent = originalText;

				if (response.data.success) {
					Craft.cp.displayNotice(T.syncAllSuccess);
					setTimeout(function() { window.location.reload(); }, 1000);
				} else {
					Craft.cp.displayError(T.syncAllPartial);
				}
			})
			.catch(function() {
				btn.disabled = false;
				btn.textContent = originalText;
				Craft.cp.displayError(T.syncAllFailed);
			});
	});

	// ---------------------------------------------------------------------
	// Row-action handlers. Delegated listener on `document`, narrowed by
	// `a[data-action]` + an explicit action-name allowlist. preventDefault
	// only after the match — leaves unrelated `data-action` elements alone.
	// See cp-table-index-pattern.md.
	// ---------------------------------------------------------------------
	document.addEventListener('click', function(e) {
		const trigger = e.target.closest('a[data-action]');
		if (!trigger) return;

		const action = trigger.dataset.action;
		if (action !== 'sync' && action !== 'delete') return;

		const id = trigger.dataset.id;
		const name = trigger.dataset.name || '';
		if (!id) return;
		e.preventDefault();

		if (action === 'sync') {
			Craft.sendActionRequest('POST', 'docs-manager/sources/sync', {
				data: { sourceId: id },
			}).then(function(response) {
				if (response.data.success) {
					Craft.cp.displayNotice(T.sourceSyncedTemplate.replace('{name}', name));
					setTimeout(function() { window.location.reload(); }, 1000);
				} else {
					Craft.cp.displayError(response.data.error || T.syncFailed);
				}
			}).catch(function() {
				Craft.cp.displayError(T.failedToSyncSource);
			});
		} else if (action === 'delete') {
			if (!confirm(T.deleteConfirmTemplate.replace('{name}', name))) return;
			Craft.sendActionRequest('POST', 'docs-manager/sources/delete', {
				data: { sourceId: id },
			}).then(function(response) {
				if (response.data && response.data.success !== false) {
					Craft.cp.displayNotice(T.sourceDeleted);
					setTimeout(function() { window.location.reload(); }, 1000);
				} else {
					Craft.cp.displayError(response.data.error || T.failedToDeleteSource);
				}
			}).catch(function() {
				Craft.cp.displayError(T.failedToDeleteSource);
			});
		}
	});

	// ---------------------------------------------------------------------
	// Bulk actions. Each posts the selected IDs to its endpoint; the
	// controller returns `count` (rows successfully changed).
	// ---------------------------------------------------------------------
	function runBulkStatus(endpoint, successTemplate, errorFallback) {
		const ids = selectedIds();
		if (!ids.length) return;
		Craft.sendActionRequest('POST', endpoint, {
			data: { sourceIds: ids },
		}).then(function(response) {
			const count = response.data.count || 0;
			if (count > 0) {
				Craft.cp.displayNotice(successTemplate.replace('{count}', count));
				setTimeout(function() { window.location.reload(); }, 1000);
			}
		}).catch(function() {
			Craft.cp.displayError(errorFallback);
		});
	}

	document.getElementById('lr-bulk-enable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		runBulkStatus('docs-manager/sources/bulk-enable', T.bulkEnabledTemplate, T.bulkEnableFailed);
	});

	document.getElementById('lr-bulk-disable-action')?.addEventListener('click', function(e) {
		e.preventDefault();
		runBulkStatus('docs-manager/sources/bulk-disable', T.bulkDisabledTemplate, T.bulkDisableFailed);
	});

	document.getElementById('lr-bulk-delete-btn')?.addEventListener('click', function() {
		const ids = selectedIds();
		if (!ids.length) return;
		const confirmTemplate = ids.length === 1 ? T.bulkDeleteConfirmSingular : T.bulkDeleteConfirmPlural;
		if (!confirm(confirmTemplate.replace('{count}', ids.length))) return;
		runBulkStatus('docs-manager/sources/bulk-delete', T.bulkDeletedTemplate, T.bulkDeleteFailed);
	});

})();
</script>
{% endblock %}
