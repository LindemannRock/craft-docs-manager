{% extends "_layouts/cp" %}

{% do view.registerAssetBundle('lindemannrock\\base\\web\\assets\\components\\ComponentsAsset') %}

{% set pluginInstance = craft.app.plugins.getPlugin('docs-manager') %}

{% set title = isNew ? 'Add Source'|t('docs-manager') : source.name %}
{% set selectedSubnavItem = 'sources' %}
{% set fullPageForm = true %}
{% set saveShortcutRedirect = cpUrl('docs-manager/sources/{id}') %}
{% set retainScrollOnSaveShortcut = true %}

{# Site crumb for multi-site #}
{% set crumbs = [] %}
{% if craft.app.getIsMultiSite() %}
    {% set currentSite = craft.app.sites.getCurrentSite() %}
    {% set siteParam = craft.app.request.getParam('site') %}
    {% set selectedSiteHandle = siteParam ?: currentSite.handle %}
    {% set selectedSite = siteParam ? craft.app.sites.getSiteByHandle(siteParam) : currentSite %}

    {% set siteMenuItems = [] %}
    {% for site in pluginInstance.getEnabledSites() %}
        {% set siteMenuItems = siteMenuItems|merge([{
            label: site.name,
            url: source.id ? url('docs-manager/sources/' ~ source.id, {site: site.handle}) : url('docs-manager/sources/new', {site: site.handle}),
            selected: site.handle == selectedSiteHandle
        }]) %}
    {% endfor %}

    {% set crumbs = [{
        id: 'site-crumb',
        icon: 'world',
        label: selectedSite.name|t('site'),
        menu: {
            items: siteMenuItems,
            label: 'Select site'|t('docs-manager')
        }
    }] %}
{% endif %}

{% set crumbs = crumbs|merge([
    { label: pluginInstance.settings.pluginName, url: url('docs-manager') },
    { label: 'Sources'|t('docs-manager'), url: url('docs-manager/sources') },
]) %}

{% if source.id %}
    {% set crumbs = crumbs|merge([{
        label: source.name,
        url: url('docs-manager/sources/' ~ source.id)
    }]) %}
{% endif %}

{% import "_includes/forms" as forms %}

{% block actionButton %}
    <div class="btngroup submit">
        <button type="submit" class="btn submit">{{ "Save"|t('docs-manager') }}</button>
        <button type="button" class="btn submit menubtn"></button>
        <div class="menu">
            <ul role="listbox">
                <li>
                    <a class="formsubmit" role="option" tabindex="0" data-redirect="{{ cpUrl('docs-manager/sources/{id}')|hash }}">
                        <span class="label">{{ 'Save and continue editing'|t('docs-manager') }}</span>
                        <span class="shortcut" id="save-shortcut"></span>
                    </a>
                </li>
            </ul>
        </div>
    </div>
    {% if source.id %}
        <button type="button" id="action-btn" class="btn menubtn action-btn hairline-dark m" title="{{ 'Actions'|t('docs-manager') }}" aria-controls="action-menu" aria-label="{{ 'Actions'|t('docs-manager') }}" data-disclosure-trigger="true" aria-expanded="false"></button>
        <div id="action-menu" class="menu menu--disclosure">
            <ul>
                <li>
                    <button class="menu-item error formsubmit" data-destructive data-action="docs-manager/sources/delete" data-params='{"sourceId":{{ source.id }}}' data-confirm="{{ 'Are you sure you want to delete this source?'|t('docs-manager') }}" data-redirect="{{ 'docs-manager/sources'|hash }}" data-headers='{"Accept":"application/json"}'>
                        <span class="icon">{{ svg('@app/icons/trash.svg') }}</span>
                        <span class="menu-item-label">{{ "Delete"|t('docs-manager') }}</span>
                    </button>
                </li>
            </ul>
        </div>
    {% endif %}
{% endblock %}

{# Display validation errors summary before content #}
{% if source is defined and source.hasErrors() %}
    {% set errorSummary = include('lindemannrock-base/_partials/error-summary', {
        errors: source.getErrors(),
        translationCategory: 'docs-manager',
        linkMode: 'data-key',
    })|trim %}
{% endif %}

{% block content %}
    <input type="hidden" name="action" value="docs-manager/sources/save">
    {{ redirectInput('docs-manager/sources') }}

    {% if not isNew %}
        <input type="hidden" name="sourceId" value="{{ source.id }}">
    {% endif %}

    {# Kind Selection #}
    {{ forms.selectField({
        first: true,
        label: 'Kind'|t('docs-manager'),
        instructions: 'What type of documentation source is this?'|t('docs-manager'),
        id: 'kind',
        name: 'source[kind]',
        value: source.kind ?? 'plugin',
        options: [
            { label: 'Plugin'|t('docs-manager'), value: 'plugin' },
            { label: 'Theme'|t('docs-manager'), value: 'theme' },
        ],
        errors: source.getErrors('kind'),
    }) }}

    {# Source Type Selection #}
    {% set hasGithubToken = pluginInstance.settings.githubToken %}
    {% set sourceOptions = [{ label: 'Local File System', value: 'local' }] %}
    {% if hasGithubToken %}
        {% set sourceOptions = sourceOptions|merge([{ label: 'GitHub API', value: 'github-api' }]) %}
    {% endif %}
    {% set sourceTypeErrors = source.getErrors('sourceType')|merge(source.getErrors('repositoryUrl'))|merge(source.getErrors('localPath')) %}

    {{ forms.selectField({
        label: 'Source Type'|t('docs-manager'),
        instructions: 'Where to read documentation for this source'|t('docs-manager'),
        id: 'sourceType',
        name: 'source[sourceType]',
        value: source.sourceType ?? pluginInstance.settings.defaultSourceType,
        options: sourceOptions,
        disabled: not isNew,
        errors: sourceTypeErrors,
    }) }}

    {# Quick Add - Auto-loads available sources #}
    {% if isNew %}
        <div class="field" id="quick-add-field">
            <div class="heading">
                <label>{{ "Quick Add"|t('docs-manager') }}</label>
            </div>
            <div class="input">
                <div id="source-selector-container"></div>
            </div>
        </div>
    {% endif %}

    <hr>

    <h2>{{ "Source Information"|t('docs-manager') }}</h2>
    <p class="light">{{ "This information is automatically synced from the source (docs/index.json or composer.json)"|t('docs-manager') }}</p>

    {{ forms.textField({
        label: 'Name'|t('docs-manager'),
        instructions: 'The display name of this source'|t('docs-manager'),
        id: 'name',
        name: 'source[name]',
        value: source.name ?? '',
        required: true,
        readonly: not isNew and not source.hasErrors(),
        errors: source.getErrors('name'),
    }) }}

    {{ forms.textField({
        label: 'Handle'|t('docs-manager'),
        instructions: 'Unique handle for this source (auto-populated from Quick Add)'|t('docs-manager'),
        id: 'handle',
        name: 'source[handle]',
        value: source.handle ?? '',
        required: true,
        readonly: not isNew and not source.hasErrors(),
        errors: source.getErrors('handle'),
    }) }}

    {{ forms.textareaField({
        label: 'Description'|t('docs-manager'),
        instructions: 'A short description of this source'|t('docs-manager'),
        id: 'description',
        name: 'source[description]',
        value: source.description ?? '',
        rows: 2,
        errors: source.getErrors('description'),
    }) }}

    {# Hidden fields - auto-populated from selector #}
    <input type="hidden" id="repositoryUrl" name="source[repositoryUrl]" value="{{ source.repositoryUrl ?? '' }}">
    <input type="hidden" id="localPath" name="source[localPath]" value="{{ source.localPath ?? '' }}">

    {% if source.id %}
        <hr>
        <h2>{{ "Docs Versions"|t('docs-manager') }}</h2>
        <p class="light">{{ "Add pinned documentation versions that sync from non-main Git refs. The main ref is always the default docs URL."|t('docs-manager') }}</p>

        <div class="tableview">
            <table class="data fullwidth" id="docs-versions-table">
                <thead>
                    <tr>
                        <th>{{ "Label"|t('docs-manager') }}</th>
                        <th>{{ "URL Slug"|t('docs-manager') }}</th>
                        <th>{{ "Git Ref"|t('docs-manager') }}</th>
                        <th>{{ "Status"|t('docs-manager') }}</th>
                        <th>{{ "Last Synced"|t('docs-manager') }}</th>
                        <th>{{ "Delete"|t('docs-manager') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for version in sourceVersions %}
                        {% set rowName = 'versions[' ~ loop.index0 ~ ']' %}
                        <tr>
                            <td>
                                <input type="hidden" name="{{ rowName }}[id]" value="{{ version.id }}">
                                <input type="hidden" name="{{ rowName }}[isDefault]" value="{{ version.isDefault ? '1' : '0' }}">
                                <input class="text fullwidth" type="text" name="{{ rowName }}[label]" value="{{ version.label }}" {{ version.isDefault ? 'readonly' : '' }}>
                                {% if version.hasErrors('label') %}<ul class="errors"><li>{{ version.getFirstError('label') }}</li></ul>{% endif %}
                            </td>
                            <td>
                                <input class="text fullwidth" type="text" name="{{ rowName }}[slug]" value="{{ version.slug }}" placeholder="{{ version.isDefault ? 'default' : 'v5' }}" {{ version.isDefault ? 'readonly' : '' }}>
                                {% if version.hasErrors('slug') %}<ul class="errors"><li>{{ version.getFirstError('slug') }}</li></ul>{% endif %}
                            </td>
                            <td>
                                <input class="text fullwidth" type="text" name="{{ rowName }}[ref]" value="{{ version.ref }}" {{ version.isDefault ? 'readonly' : '' }}>
                                {% if version.hasErrors('ref') %}<ul class="errors"><li>{{ version.getFirstError('ref') }}</li></ul>{% endif %}
                            </td>
                            <td>
                                {% if version.isDefault %}
                                    <input type="hidden" name="{{ rowName }}[status]" value="latest">
                                    <span class="status green"></span>{{ "Latest"|t('docs-manager') }}
                                {% else %}
                                    <div class="select">
                                        <select name="{{ rowName }}[status]">
                                            {% for statusValue, statusLabel in versionStatusOptions %}
                                                <option value="{{ statusValue }}" {{ version.status == statusValue ? 'selected' : '' }}>{{ statusLabel }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    {% if version.hasErrors('status') %}<ul class="errors"><li>{{ version.getFirstError('status') }}</li></ul>{% endif %}
                                {% endif %}
                                <input type="hidden" name="{{ rowName }}[sortOrder]" value="{{ loop.index0 }}">
                            </td>
                            <td>
                                {% if version.lastSyncedAt %}
                                    {{ version.lastSyncedAt|lrDatetime }}
                                {% else %}
                                    <span class="light">{{ "Never"|t('docs-manager') }}</span>
                                {% endif %}
                                {% if version.lastSyncStatus == 'error' and version.lastSyncError %}
                                    <div class="error" style="margin-top: 4px;">{{ version.lastSyncError|nl2br }}</div>
                                {% endif %}
                            </td>
                            <td>
                                {% if version.isDefault %}
                                    <span class="light">-</span>
                                {% else %}
                                    <label>
                                        <input type="checkbox" name="{{ rowName }}[delete]" value="1">
                                    </label>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div style="margin-top: 12px;">
            <button type="button" class="btn" id="add-docs-version-btn">{{ "Add version"|t('docs-manager') }}</button>
        </div>
    {% endif %}

    {# Custom Pages link (only for existing sources) #}
    {% if source.id and currentUser.can('docsManager:managePages') %}
        <hr>
        <h2>{{ "Custom Pages"|t('docs-manager') }}</h2>
        {% set customPages = craft.docsManager.getCustomPages(source.handle) %}
        <div style="margin-top: 12px;">
            <a href="{{ url('docs-manager/pages', { sourceId: source.id }) }}" class="btn">
                {{ "View Custom Pages ({count})"|t('docs-manager', { count: customPages|length }) }}
            </a>
        </div>
    {% endif %}

    {% include 'lindemannrock-base/_components/plugin-credit' %}
{% endblock %}

{% block details %}
    {# Version display (read-only) - only show if exists #}
    {% if source.id and source.currentVersion %}
        <div class="meta">
            <div class="field" data-attribute="version">
                <div class="heading">
                    <label>{{ "Version"|t('docs-manager') }}</label>
                </div>
                <div class="input ltr">
                    <div class="value"><code style="font-size: 13px;">{{ source.currentVersion }}</code></div>
                </div>
            </div>
        </div>
    {% endif %}

    <fieldset>
        <legend class="h6">{{ "Status"|t('docs-manager') }}</legend>
        <div class="meta">
            {{ forms.lightswitchField({
                label: "Enabled"|t('docs-manager'),
                instructions: "Include this source in sync operations"|t('docs-manager'),
                id: 'enabled',
                name: 'source[enabled]',
                on: source.enabled ?? true,
            }) }}
        </div>
    </fieldset>

    {% if source.id %}
        <fieldset>
            <legend class="h6">{{ "Sync"|t('docs-manager') }}</legend>
            <div class="meta" style="padding-top: 16px; padding-bottom: 16px;">
                <button type="button" id="sync-source-btn" class="btn secondary fullwidth">
                    {{ "Resync Source Data"|t('docs-manager') }}
                </button>
            </div>
        </fieldset>
    {% endif %}

    {% if source.id %}
        <dl class="meta read-only">
            <div class="data">
                <dt class="heading">{{ "ID"|t('docs-manager') }}</dt>
                <dd class="value">{{ source.id }}</dd>
            </div>
            <div class="data">
                <dt class="heading">{{ "Status"|t('docs-manager') }}</dt>
                <dd class="value">
                    {% include 'lindemannrock-base/_components/status-dot' with {
                        value: source.enabled ? 'enabled' : 'disabled',
                        colorSet: 'status',
                    } only %}
                    <span>{{ source.enabled ? 'Enabled'|t('docs-manager') : 'Disabled'|t('docs-manager') }}</span>
                </dd>
            </div>
            <div class="data">
                <dt class="heading">{{ "Handle"|t('docs-manager') }}</dt>
                <dd class="value"><code>{{ source.handle }}</code></dd>
            </div>
            <div class="data">
                <dt class="heading">{{ "Kind"|t('docs-manager') }}</dt>
                <dd class="value">
                    {% include 'lindemannrock-base/_components/status-dot' with {
                        value: source.kind,
                        colorSet: 'sourceKind',
                    } only %}
                    <span>{{ source.kind|capitalize }}</span>
                </dd>
            </div>
            <div class="data">
                <dt class="heading">{{ "Pages"|t('docs-manager') }}</dt>
                <dd class="value">{{ craft.docsManager.getPages(source.handle)|length }}</dd>
            </div>
            {% if source.lastSyncedAt %}
                <div class="data">
                    <dt class="heading">{{ "Last Synced"|t('docs-manager') }}</dt>
                    <dd class="value">{{ source.lastSyncedAt|lrDatetime }}</dd>
                </div>
            {% endif %}
            <div class="data">
                <dt class="heading">{{ "Created at"|t('docs-manager') }}</dt>
                <dd class="value">{{ source.dateCreated|lrDatetime }}</dd>
            </div>
            <div class="data">
                <dt class="heading">{{ "Updated at"|t('docs-manager') }}</dt>
                <dd class="value">{{ source.dateUpdated|lrDatetime }}</dd>
            </div>
        </dl>
    {% endif %}
{% endblock %}

{% js %}
    // Initialize disclosure menu
    if (typeof Craft !== 'undefined' && Craft.ui && Craft.ui.createDisclosureMenu) {
        const actionBtn = document.getElementById('action-btn');
        if (actionBtn) {
            new Craft.ui.createDisclosureMenu(actionBtn);
        }
    }

    {% if source.id %}
        // Sync source button
        document.getElementById('sync-source-btn').addEventListener('click', function() {
            const btn = this;
            const originalText = btn.textContent;
            btn.disabled = true;
            btn.textContent = '{{ "Syncing..."|t('docs-manager') }}';

            Craft.sendActionRequest('POST', 'docs-manager/sources/sync', {
                data: { sourceId: {{ source.id }} }
            })
            .then(response => {
                btn.disabled = false;
                btn.textContent = originalText;

                if (response.data.success) {
                    Craft.cp.displayNotice('{{ "Source synced successfully"|t('docs-manager') }}');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    Craft.cp.displayError(response.data.error || '{{ "Sync failed"|t('docs-manager') }}');
                }
            })
            .catch(error => {
                btn.disabled = false;
                btn.textContent = originalText;
                Craft.cp.displayError('{{ "Failed to sync source"|t('docs-manager') }}');
            });
        });
    {% endif %}

    {% if source.id %}
        let docsVersionIndex = {{ sourceVersions|length }};
        const docsVersionsTable = document.querySelector('#docs-versions-table tbody');
        const addDocsVersionBtn = document.getElementById('add-docs-version-btn');
        if (docsVersionsTable && addDocsVersionBtn) {
            addDocsVersionBtn.addEventListener('click', function() {
                const rowName = `versions[${docsVersionIndex}]`;
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>
                        <input class="text fullwidth" type="text" name="${rowName}[label]" value="" placeholder="5.x">
                        <input type="hidden" name="${rowName}[isDefault]" value="0">
                    </td>
                    <td><input class="text fullwidth" type="text" name="${rowName}[slug]" value="" placeholder="v5"></td>
                    <td><input class="text fullwidth" type="text" name="${rowName}[ref]" value="" placeholder="craft-5"></td>
                    <td>
                        <div class="select">
                            <select name="${rowName}[status]">
                                {% for statusValue, statusLabel in versionStatusOptions %}
                                    <option value="{{ statusValue }}" {{ statusValue == 'stable' ? 'selected' : '' }}>{{ statusLabel }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <input type="hidden" name="${rowName}[sortOrder]" value="${docsVersionIndex}">
                    </td>
                    <td><span class="light">{{ "Never"|t('docs-manager') }}</span></td>
                    <td><label><input type="checkbox" name="${rowName}[delete]" value="1"></label></td>
                `;
                docsVersionsTable.appendChild(row);
                docsVersionIndex++;
            });
        }
    {% endif %}

    {% if isNew %}
        window.lrIdentifiers?.bindSlugHandle('#name', '#handle', {
            isNew: true,
        });

        // Auto-load available sources when source type or kind changes
        const sourceTypeSelect = document.getElementById('sourceType');
        const kindSelect = document.getElementById('kind');
        const selectorContainer = document.getElementById('source-selector-container');

        function loadAvailableSources() {
            const sourceType = sourceTypeSelect.value;

            if (sourceType === 'local') {
                loadLocalSources();
            } else if (sourceType === 'github-api') {
                loadGithubSources();
            }
        }

        function filterByKind(sources) {
            const selectedKind = kindSelect.value;
            return sources.filter(s => s.kind === selectedKind);
        }

        function loadLocalSources() {
            selectorContainer.innerHTML = '<p class="light">{{ "Loading local sources..."|t('docs-manager') }}</p>';

            Craft.sendActionRequest('POST', 'docs-manager/sources/scan-local')
                .then(response => {
                    const filtered = filterByKind(response.data.sources || []);
                    if (filtered.length > 0) {
                        showSourceSelector(filtered);
                    } else {
                        selectorContainer.innerHTML = '<p class="light">{{ "No new sources found for this kind."|t('docs-manager') }}</p>';
                    }
                })
                .catch(error => {
                    selectorContainer.innerHTML = '<p class="error">{{ "Failed to load local sources"|t('docs-manager') }}</p>';
                });
        }

        function loadGithubSources() {
            selectorContainer.innerHTML = '<p class="light">{{ "Loading GitHub repositories..."|t('docs-manager') }}</p>';

            Craft.sendActionRequest('POST', 'docs-manager/sources/scan-github')
                .then(response => {
                    let html = '';

                    const filtered = filterByKind(response.data.sources || []);
                    if (filtered.length > 0) {
                        showSourceSelector(filtered);
                        return;
                    }

                    html = '<p class="light">{{ "No new sources found for this kind."|t('docs-manager') }}</p>';

                    if (response.data.missingIndexJson && response.data.missingIndexJson.length > 0) {
                        html += '<div style="margin-top: 16px; padding: 12px; background: #fef3cd; border: 1px solid #f0ad4e; border-radius: 4px;">';
                        html += '<p style="margin: 0 0 8px 0; font-weight: 600;">{{ "Sources missing docs/index.json:"|t('docs-manager') }}</p>';
                        html += '<ul style="margin: 0; padding-left: 20px;">';
                        response.data.missingIndexJson.forEach(s => {
                            html += `<li><a href="${s.url}" target="_blank">${s.name}</a> - <span class="light">Create docs/index.json to enable syncing</span></li>`;
                        });
                        html += '</ul>';
                        html += '</div>';
                    }

                    selectorContainer.innerHTML = html;
                })
                .catch(error => {
                    selectorContainer.innerHTML = '<p class="error">{{ "Failed to load GitHub repositories. Check your GitHub token in settings."|t('docs-manager') }}</p>';
                });
        }

        function showSourceSelector(sources) {
            let html = '<div class="select"><select id="discovered-sources" class="fullwidth">';
            html += '<option value="">{{ "Select a source to add..."|t('docs-manager') }}</option>';

            sources.forEach(s => {
                html += `<option value='${JSON.stringify(s)}'>${s.name} (${s.handle})</option>`;
            });

            html += '</select></div>';
            html += '<p class="light" style="margin-top: 8px;">{{ "Select a source from the list to auto-fill the form below"|t('docs-manager') }}</p>';

            selectorContainer.innerHTML = html;

            document.getElementById('discovered-sources').addEventListener('change', function() {
                if (this.value) {
                    const source = JSON.parse(this.value);
                    populateForm(source);
                }
            });
        }

        function populateForm(source) {
            document.getElementById('name').value = source.name || '';
            document.getElementById('handle').value = source.handle || '';
            document.getElementById('description').value = source.description || '';

            if (source.kind) {
                document.getElementById('kind').value = source.kind;
            }
            if (source.repositoryUrl) {
                document.getElementById('repositoryUrl').value = source.repositoryUrl;
            }
            if (source.localPath) {
                document.getElementById('localPath').value = source.localPath;
            }

            Craft.cp.displayNotice('{{ "Source details populated. Review and save."|t('docs-manager') }}');
        }

        sourceTypeSelect.addEventListener('change', loadAvailableSources);
        kindSelect.addEventListener('change', loadAvailableSources);
        loadAvailableSources();
    {% endif %}
{% endjs %}
