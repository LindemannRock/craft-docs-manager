{#
/**
 * Documentation Page Template
 *
 * INSTRUCTIONS:
 * Copy to: templates/plugins/_doc.twig
 * URL: /plugins/{handle}/docs/{slug}
 *
 * Displays documentation content with:
 * - Left sidebar: Navigation by category
 * - Main content: Parsed HTML from markdown
 * - Right sidebar: "On This Page" anchor links
 */
#}
{% extends "plugins/_layout" %}

{# Get plugin handle and doc slug from URL #}
{% set handle = craft.app.request.getSegment(2) %}
{% set slug = craft.app.request.getSegment(4) %}

{# Fetch plugin and page #}
{% set plugin = craft.pluginDocs.getPlugin(handle) %}
{% set page = craft.pluginDocs.getPage(handle, slug) %}

{% if not page %}
    {% redirect 404 %}
{% endif %}

{# Get navigation structure #}
{% set navigation = craft.pluginDocs.getNavigation(handle) %}

{# Parse headings JSON #}
{% set headings = craft.pluginDocs.getAnchors(page) %}

{% block title %}{{ page.title }} - {{ plugin.name }}{% endblock %}

{% block content %}
<div class="flex gap-8">
    {# LEFT SIDEBAR - Navigation #}
    <aside class="w-64 flex-shrink-0 sticky top-20 self-start max-h-screen overflow-y-auto">
        <div class="mb-6 space-y-2">
            <a href="/plugins/{{ handle }}" class="block text-sm text-gray-600 hover:text-gray-900">
                ← Back to {{ plugin.name }}
            </a>
            <a href="/plugins/{{ handle }}/changelog" class="block text-sm text-purple-600 hover:text-purple-800 font-medium">
                📋 Changelog
            </a>
        </div>

        <nav class="space-y-6">
            {% for categoryKey, group in navigation %}
                <div>
                    <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
                        {{ group.label }}
                    </h4>
                    <ul class="space-y-1">
                        {% for navPage in group.pages %}
                            <li>
                                <a href="/plugins/{{ handle }}/docs/{{ navPage.slug }}"
                                   class="block py-1 px-2 rounded {{ navPage.slug == slug ? 'bg-blue-50 text-blue-700 font-medium' : 'text-gray-700 hover:bg-gray-100' }}">
                                    {{ navPage.title }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}
        </nav>
    </aside>

    {# MAIN CONTENT #}
    <article class="flex-1 max-w-3xl bg-white rounded-lg border border-gray-200 p-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-6">{{ page.title }}</h1>

        {# Render parsed HTML content #}
        <div class="prose prose-blue max-w-none">
            {{ page.htmlContent|raw }}
        </div>

        {# Previous/Next Navigation #}
        {% set prevNext = craft.pluginDocs.getPrevNextPages(handle, slug) %}

        <div class="mt-12 pt-8 border-t flex justify-between">
            {% if prevNext.prev %}
                <a href="/plugins/{{ handle }}/docs/{{ prevNext.prev.slug }}"
                   class="text-blue-600 hover:text-blue-800">
                    ← {{ prevNext.prev.title }}
                </a>
            {% else %}
                <span></span>
            {% endif %}

            {% if prevNext.next %}
                <a href="/plugins/{{ handle }}/docs/{{ prevNext.next.slug }}"
                   class="text-blue-600 hover:text-blue-800">
                    {{ prevNext.next.title }} →
                </a>
            {% endif %}
        </div>
    </article>

    {# RIGHT SIDEBAR - On This Page #}
    <aside class="w-48 flex-shrink-0 sticky top-20 self-start">
        {% if headings|length > 0 %}
            <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
                On This Page
            </h4>
            <ul class="space-y-2 text-sm">
                {% for heading in headings %}
                    <li class="{{ heading.level == 3 ? 'ml-4' : '' }}">
                        <a href="#{{ heading.anchor }}"
                           class="text-gray-600 hover:text-gray-900">
                            {{ heading.text }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </aside>
</div>
{% endblock %}
